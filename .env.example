# Pugmark configuration template
# Copy to .env and fill in real values; .env is gitignored.

# LLM providers (LiteLLM picks them up by env var)
GEMINI_API_KEY=
GROQ_API_KEY=
# OLLAMA_API_BASE=http://localhost:11434  # optional, only for offline dev

# Langfuse (cloud free tier signup at https://cloud.langfuse.com)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# Provider fallback order (comma-separated)
PUGMARK_PROVIDERS=gemini,groq,ollama
PUGMARK_PRIMARY_MODEL=gemini/gemini-2.0-flash

# Judge / analyzer models (autolabel, in-book validate tier, book analyzer).
# Same fallback mechanics as primary; defaults to gemini-2.5-pro then chain.
PUGMARK_JUDGE_MODEL=gemini/gemini-2.5-pro
PUGMARK_JUDGE_PROVIDERS=gemini,groq
PUGMARK_ANALYZER_MODEL=gemini/gemini-2.5-pro
PUGMARK_ANALYZER_PROVIDERS=gemini,groq

# Chunked extraction (large chapters are split into overlapping windows and
# fanned out to the LLM in parallel; candidates merged + deduped after).
PUGMARK_CHUNK_TOKENS=6000
PUGMARK_CHUNK_OVERLAP=600
PUGMARK_EXTRACT_CONCURRENCY=3
