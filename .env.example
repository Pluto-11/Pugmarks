# Pugmark configuration template
# Copy to .env and fill in real values; .env is gitignored.

# LLM providers (LiteLLM picks them up by env var)
GEMINI_API_KEY=
GROQ_API_KEY=
# OLLAMA_API_BASE=http://localhost:11434  # optional, only for offline dev

# Langfuse (cloud free tier signup at https://cloud.langfuse.com)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# Provider fallback order (comma-separated)
PUGMARK_PROVIDERS=gemini,groq,ollama
PUGMARK_PRIMARY_MODEL=gemini/gemini-2.0-flash
