<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <title>Pugmark — {{ gallery.chapter.title }}</title>
  <style>
    body { font-family: Georgia, serif; max-width: 980px; margin: 2rem auto; padding: 0 1rem; line-height: 1.5; color: #222; }
    h1 { border-bottom: 2px solid #444; padding-bottom: 0.5rem; }
    .meta { color: #666; font-size: 0.9rem; }
    .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1.5rem; margin-top: 2rem; }
    .card { border: 1px solid #ddd; border-radius: 6px; overflow: hidden; background: #fafafa; }
    .card img { width: 100%; height: 200px; object-fit: cover; display: block; }
    .card-body { padding: 1rem; }
    .card h2 { margin: 0 0 0.5rem; font-size: 1.1rem; }
    .card .canonical { color: #888; font-style: italic; font-size: 0.9rem; }
    .card .summary { font-size: 0.9rem; margin: 0.5rem 0; }
    .card .sightings { font-size: 0.8rem; color: #555; }
    .card .license { font-size: 0.7rem; color: #888; margin-top: 0.5rem; }
    .badge { display: inline-block; padding: 0.2rem 0.5rem; border-radius: 3px; background: #e8f4f8; color: #246; font-size: 0.8rem; }
    .unresolved { margin-top: 2rem; padding: 1rem; background: #fff8e1; border-left: 3px solid #fb0; }
  </style>
</head>
<body>
  <h1>{{ gallery.chapter.title }}</h1>
  <div class="meta">
    {{ gallery.chapter.book }} · pages {{ gallery.chapter.page_start }}–{{ gallery.chapter.page_end }} · generated {{ gallery.generated_at.strftime("%Y-%m-%d %H:%M") }}
  </div>

  {% if gallery.eval_metrics %}
    <div class="badge">
      P={{ "%.2f"|format(gallery.eval_metrics.extraction.precision) }}
      R={{ "%.2f"|format(gallery.eval_metrics.extraction.recall) }}
      F1={{ "%.2f"|format(gallery.eval_metrics.extraction.f1) }}
      ({{ gallery.eval_metrics.llm_provider }} / {{ gallery.eval_metrics.prompt_version }})
    </div>
  {% endif %}

  <div class="grid">
  {% for card in gallery.cards %}
    <article class="card">
      <a href="{{ card.wikipedia_url }}" target="_blank" rel="noopener">
        <img src="{{ card.primary_image.url }}" alt="{{ card.taxon.vernacular }}">
      </a>
      <div class="card-body">
        <h2><a href="{{ card.wikipedia_url }}" target="_blank" rel="noopener">{{ card.taxon.vernacular }}</a></h2>
        <div class="canonical">{{ card.taxon.canonical_name }} · {{ card.taxon.rank }}</div>
        <p class="summary">{{ card.wikipedia_summary }}</p>
        <div class="sightings">Pages: {% for s in card.sightings %}{{ s.page }}{% if not loop.last %}, {% endif %}{% endfor %}</div>
        <div class="license">{{ card.primary_image.license }} · {{ card.primary_image.attribution }}</div>
      </div>
    </article>
  {% endfor %}
  </div>

  {% if gallery.unresolved %}
    <div class="unresolved">
      <strong>Unresolved ({{ gallery.unresolved|length }})</strong> — candidates the validator could not confirm:
      <ul>
      {% for c in gallery.unresolved %}
        <li><em>{{ c.surface_form }}</em> ({{ c.kingdom_hint }}, p. {{ c.page }})</li>
      {% endfor %}
      </ul>
    </div>
  {% endif %}

  <footer class="meta" style="margin-top: 3rem; border-top: 1px solid #ddd; padding-top: 1rem;">
    Generated by Pugmark v{{ gallery.pugmark_version }}
  </footer>
</body>
</html>
